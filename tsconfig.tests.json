{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "rootDir": ".",
    "outDir": ".test-dist",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "tests/**/*.test.ts"
  ]
}
