{
  "name": "stylo",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/generate-skill-manifest.mjs",
    "dev": "vite",
    "prebuild": "node scripts/generate-skill-manifest.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit --strict --pretty false",
    "test": "node scripts/run-tests.mjs",
    "audit": "npm audit --audit-level=high",
    "check": "npm run typecheck && npm test && npm run build && npm run audit",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "desktop:dev": "concurrently -k \"npm run dev -- --host 127.0.0.1\" \"wait-on http://127.0.0.1:3000 && cross-env STYLO_DESKTOP_URL=http://127.0.0.1:3000 electron .\"",
    "desktop:pack": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "desktop:dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "desktop:dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win zip --x64 --publish never",
    "desktop:dist:win:installer": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --x64 --publish never",
    "desktop:dist:signed": "npm run build && electron-builder"
  },
  "build": {
    "appId": "ai.stylo.desktop",
    "productName": "Stylo",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "electron/assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@clerk/backend": "^1.15.1",
    "@clerk/clerk-react": "^5.26.0",
    "@openai/agents": "^0.5.4",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.88.0",
    "@xyflow/react": "^12.10.0",
    "framer-motion": "^12.35.2",
    "konva": "^9.3.22",
    "lucide-react": "^0.555.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^19.2.3",
    "react-konva": "^18.2.10",
    "recharts": "^3.5.1",
    "three": "^0.165.0",
    "yjs": "^13.6.31",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^22.14.0",
    "@types/three": "^0.165.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^7.3.6",
    "wait-on": "^9.0.10",
    "wrangler": "^4.112.0"
  }
}
